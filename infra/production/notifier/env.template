# =============================================================================
# Frontman Notifier Environment Template
#
# Copy to /opt/frontman-notifier/env on the production server and fill secrets.
# =============================================================================

# --- Database (local PostgreSQL, no SSL) ---
DATABASE_URL=ecto://frontman:DB_PASSWORD@localhost/frontman_server_prod
DATABASE_SSL=false

# --- Discord Notifications ---
DISCORD_STARGAZERS_WEBHOOK_URL=CHANGE_ME
DISCORD_TASK_SUMMARIES_WEBHOOK_URL=CHANGE_ME

# --- GitHub API ---
# Optional, but recommended to avoid unauthenticated rate limits.
GITHUB_TOKEN=CHANGE_ME
FRONTMAN_NOTIFIER_GITHUB_REPOSITORY=frontman-ai/frontman

# --- Scheduler and state ---
FRONTMAN_NOTIFIER_STATE_DIR=/opt/frontman-notifier/state
FRONTMAN_NOTIFIER_CHECK_INTERVAL_MS=3600000
FRONTMAN_NOTIFIER_TASK_LOOKBACK_HOURS=24
FRONTMAN_NOTIFIER_TASK_IDLE_MINUTES=30
FRONTMAN_NOTIFIER_TASK_MAX_PER_RUN=20
FRONTMAN_NOTIFIER_GITHUB_STARGAZER_PAGES=3

# --- Release distribution ---
RELEASE_NODE=frontman_notifier@127.0.0.1
RELEASE_COOKIE=GENERATED_BY_SETUP_SCRIPT
RELEASE_DISTRIBUTION=name
