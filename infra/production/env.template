# =============================================================================
# Frontman Server Environment Template
#
# Copy to /opt/frontman/{blue,green}/env on the production server.
# Blue uses PORT=4000, Green uses PORT=4001.
#
# Generated values are created by server-setup.sh; secrets must be filled in.
# =============================================================================

# --- Slot-specific (blue: 4000, green: 4001) ---
PORT=4000
RELEASE_NODE=frontman_blue@127.0.0.1
RELEASE_COOKIE=GENERATED_BY_SETUP_SCRIPT
RELEASE_DISTRIBUTION=name

# --- Application ---
PHX_HOST=api.frontman.sh
PHX_SERVER=true

# --- Database (local PostgreSQL, no SSL) ---
DATABASE_URL=ecto://frontman:DB_PASSWORD@localhost/frontman_server_prod
DATABASE_SSL=false

# --- Security ---
SECRET_KEY_BASE=GENERATED_BY_SETUP_SCRIPT

# --- Encryption at rest (Cloak) ---
CLOAK_KEY=CHANGE_ME

# --- Authentication (WorkOS) ---
WORKOS_API_KEY=CHANGE_ME
WORKOS_CLIENT_ID=CHANGE_ME

# --- Discord Notifications ---
# Webhook URL for #new-users signup alerts
DISCORD_NEW_USERS_WEBHOOK_URL=CHANGE_ME

# --- Email (Resend) ---
RESEND_API_KEY=CHANGE_ME
