---
// Install Steps Section
// ------------
// Description: A section displaying the 3-step installation process for Frontman
// Uses a vertical timeline layout with horizontal step rows

// Components
// - Decorative
import FloatingBlobs from '../../ui/decorative/FloatingBlobs.astro'

// Assets
import nextjsLogo from '../../../assets/frameworks/nextjs.svg'
import astroLogo from '../../../assets/frameworks/astro.svg'
import viteLogo from '../../../assets/frameworks/vite.svg'

const frameworks = [
	{
		id: 'nextjs',
		name: 'Next.js',
		logo: nextjsLogo,
		command: 'npx @frontman-ai/nextjs install',
		url: 'http://localhost:3000/frontman',
		step1Title: 'Add to your project',
		step1Description: 'Run one command in your project folder',
		step2Title: 'Open Frontman',
		step2Description: 'Visit localhost/frontman in your browser',
		step3Title: 'Connect your AI',
		step3Description: 'Connect to your preferred AI model subscription',
		showPluginLink: 'false'
	},
	{
		id: 'astro',
		name: 'Astro',
		logo: astroLogo,
		command: 'astro add @frontman-ai/astro',
		url: 'http://localhost:4321/frontman',
		step1Title: 'Add to your project',
		step1Description: 'Run one command in your project folder',
		step2Title: 'Open Frontman',
		step2Description: 'Visit localhost/frontman in your browser',
		step3Title: 'Connect your AI',
		step3Description: 'Connect to your preferred AI model subscription',
		showPluginLink: 'false'
	},
	{
		id: 'vite',
		name: 'Vite',
		logo: viteLogo,
		command: 'npx @frontman-ai/vite install',
		url: 'http://localhost:5173/frontman',
		step1Title: 'Add to your project',
		step1Description: 'Run one command in your project folder',
		step2Title: 'Open Frontman',
		step2Description: 'Visit localhost/frontman in your browser',
		step3Title: 'Connect your AI',
		step3Description: 'Connect to your preferred AI model subscription',
		showPluginLink: 'false'
	},
	{
		id: 'wordpress',
		name: 'WordPress',
		logo: { src: '/logo.svg' },
		command: 'Plugins -> Add New Plugin',
		url: 'https://yoursite.com/frontman',
		step1Title: 'Install the plugin',
		step1Description: 'Search for Frontman Agentic AI Editor in wp-admin',
		step2Title: 'Activate and open Frontman',
		step2Description: 'Visit /frontman on your WordPress site',
		step3Title: 'Describe a site change',
		step3Description: 'Connect your AI provider, describe the edit, and review it beside live preview',
		showPluginLink: 'true'
	}
]
---

<section id="install" class="install-section">
	<FloatingBlobs
		blobs={[
			{ color: '#9D7CFF', size: 450, startX: -12, startY: 50 },
			{ color: '#60A5FA', size: 550, startX: 85, startY: -15 },
			{ color: '#FCD34D', size: 500, startX: 82, startY: 90 }
		]}
		speed={20}
	/>

	<div class="container">
		<div class="install-header">
			<h2 class="install-title">Up and running in under 5 minutes</h2>
			<p class="install-subtitle">
				One command to install, one URL to open, one AI to connect. That's it.
			</p>

			<div class="framework-tabs">
				{frameworks.map((fw, i) => (
				<button
					class={`framework-tab ${i === 0 ? 'active' : ''}`}
					data-framework={fw.id}
					data-command={fw.command}
					data-url={fw.url}
					data-step1-title={fw.step1Title}
					data-step1-description={fw.step1Description}
					data-step2-title={fw.step2Title}
					data-step2-description={fw.step2Description}
					data-step3-title={fw.step3Title}
					data-step3-description={fw.step3Description}
					data-show-plugin-link={fw.showPluginLink}
				>
						<img src={fw.logo.src} alt="" width="24" height="24" loading="lazy" aria-hidden="true" />
						{fw.name}
					</button>
				))}
			</div>
		</div>

		<div class="steps-timeline">
			<!-- Step 1 -->
			<div class="step">
				<div class="step-indicator">
					<div class="step-number step-number--yellow">1</div>
					<div class="step-line"></div>
				</div>
				<div class="step-card step-card--yellow">
					<h3 class="step-title" data-step1-title>Add to your project</h3>
					<p class="step-description" data-step1-description>Run one command in your project folder</p>
					<div class="terminal">
						<div class="terminal-bar">
							<span class="terminal-dot"></span>
							<span class="terminal-dot"></span>
							<span class="terminal-dot"></span>
						</div>
						<div class="terminal-body">
							<span class="terminal-prompt">$</span>
							<code data-install-command>npx @frontman-ai/nextjs install</code>
							<button class="copy-button" data-copy="install" aria-label="Copy to clipboard">
								<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
									<rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
									<path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
								</svg>
							</button>
						</div>
					</div>
					<a class="plugin-directory-link" data-plugin-directory-link href="https://wordpress.org/plugins/frontman-agentic-ai-editor/" target="_blank" rel="noopener noreferrer" hidden>Open WordPress Plugin Directory &rarr;</a>
				</div>
			</div>

			<!-- Step 2 -->
			<div class="step">
				<div class="step-indicator">
					<div class="step-number step-number--pink">2</div>
					<div class="step-line"></div>
				</div>
				<div class="step-card step-card--pink">
					<h3 class="step-title" data-step2-title>Open Frontman</h3>
					<p class="step-description" data-step2-description>Visit localhost/frontman in your browser</p>
					<div class="terminal">
						<div class="terminal-bar">
							<span class="terminal-dot"></span>
							<span class="terminal-dot"></span>
							<span class="terminal-dot"></span>
						</div>
						<div class="terminal-body">
						<svg class="url-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
							<circle cx="12" cy="12" r="10"></circle>
							<line x1="2" y1="12" x2="22" y2="12"></line>
							<path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
						</svg>
							<code data-port-url>http://localhost:3000/frontman</code>
						<button class="copy-button" data-copy="url" aria-label="Copy to clipboard">
							<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
								<rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
								<path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
							</svg>
						</button>
						</div>
					</div>
				</div>
			</div>

			<!-- Step 3 -->
			<div class="step step--last">
				<div class="step-indicator">
					<div class="step-number step-number--peach">3</div>
				</div>
				<div class="step-card step-card--peach">
					<h3 class="step-title" data-step3-title>Connect your AI</h3>
					<p class="step-description" data-step3-description>Connect to your preferred AI model subscription</p>
					<div class="ai-badges">
						<span class="ai-badge">Claude</span>
						<span class="ai-badge">ChatGPT</span>
						<span class="ai-badge">OpenRouter</span>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	@reference "../../../styles/global.css";
	.install-section {
		@apply relative overflow-hidden py-16 lg:py-32;
		background: #FAFAFA;
	}

	.container {
		@apply relative z-[100] mx-auto max-w-3xl px-6;
	}

	/* Header */
	.install-header {
		@apply text-center mb-10 lg:mb-20;
	}

	.install-title {
		@apply font-headings text-3xl md:text-5xl lg:text-6xl font-bold text-black;
	}

	.install-subtitle {
		@apply mt-4 lg:mt-6 text-base lg:text-xl max-w-2xl mx-auto leading-relaxed;
		color: #334155;
	}

	/* Framework tabs */
	.framework-tabs {
		@apply mt-8 flex flex-wrap items-center justify-center gap-3;
	}

	.framework-tab {
		@apply flex items-center gap-2 px-5 py-2.5 text-base font-medium cursor-pointer transition-all border-2;
		background: #ffffff;
		border-color: #e5e5e5;
		border-radius: 9999px;
		color: #525252;
	}

	.framework-tab:hover {
		border-color: #a3a3a3;
	}

	.framework-tab.active {
		border-color: #000000;
		color: #000000;
		background: #ffffff;
		box-shadow: 3px 3px 0 0 rgba(0, 0, 0, 1);
	}

	.framework-tab img {
		@apply w-5 h-5;
		object-fit: contain;
	}

	/* Timeline */
	.steps-timeline {
		@apply flex flex-col;
	}

	.step {
		@apply flex gap-3 lg:gap-8;
		min-width: 0;
	}

	/* Step indicator */
	.step-indicator {
		@apply hidden lg:flex flex-col items-center flex-shrink-0;
	}

	.step-number {
		@apply flex items-center justify-center w-10 h-10 lg:w-14 lg:h-14 font-headings text-base lg:text-xl font-bold text-white border-2 border-black;
		border-radius: 50%;
		box-shadow: 3px 3px 0 0 rgba(0, 0, 0, 1);
	}

	.step-number--yellow { background-color: #FCD34D; }
	.step-number--pink { background-color: #F472B6; }
	.step-number--peach { background-color: #FB923C; }

	.step-line {
		@apply flex-1 my-3;
		width: 2px;
		background: repeating-linear-gradient(
			to bottom,
			#d4d4d4 0px,
			#d4d4d4 6px,
			transparent 6px,
			transparent 12px
		);
		min-height: 24px;
	}

	/* Step cards */
	.step-card {
		@apply flex-1 rounded-2xl p-4 lg:p-6 mb-6;
		border-left: 4px solid transparent;
		min-width: 0;
	}

	.step-card--yellow {
		background: #FFF8E1;
		border-left-color: #F59E0B;
	}
	.step-card--pink {
		background: #FFF0F6;
		border-left-color: #EC4899;
	}
	.step-card--peach {
		background: #FFF3EC;
		border-left-color: #F97316;
	}

	.step--last .step-card {
		@apply mb-0;
	}

	.step-title {
		@apply font-headings text-xl lg:text-2xl font-bold text-black;
	}

	.step-description {
		@apply mt-2 text-sm lg:text-base leading-relaxed;
		color: #334155;
	}

	/* Terminal code block */
	.terminal {
		@apply mt-5;
		background: #0f0f1a;
		border-radius: 12px;
		border: 2px solid #1e1e2e;
		overflow: hidden;
	}

	.terminal-bar {
		@apply flex items-center gap-1.5 px-3 lg:px-4 py-2.5;
		background: #1a1a2e;
		border-bottom: 1px solid #2a2a3e;
	}

	.terminal-dot {
		@apply block w-2.5 h-2.5 rounded-full;
		background: #3a3a4e;
	}

	.terminal-body {
		@apply flex items-center gap-2 lg:gap-3 px-3 lg:px-4 py-3.5 font-mono;
		font-size: 13px;
		overflow-x: auto;
	}

	@media (min-width: 1024px) {
		.terminal-body {
			font-size: 14px;
		}
	}

	.terminal-prompt {
		@apply flex-shrink-0 font-bold;
		color: #22c55e;
	}

	.terminal-body code {
		@apply flex-1;
		color: #C084FF;
		white-space: nowrap;
	}

	.url-icon {
		@apply flex-shrink-0;
		color: #64748b;
	}

	.copy-button {
		@apply flex-shrink-0 p-2 transition-all cursor-pointer rounded-lg;
		background: rgba(255, 255, 255, 0.05);
		border: 1px solid rgba(255, 255, 255, 0.08);
		color: #64748b;
	}

	.copy-button:hover {
		background: rgba(255, 255, 255, 0.12);
		color: #C084FF;
	}

	.plugin-directory-link {
		@apply mt-4 inline-flex text-sm font-semibold text-primary-600 underline underline-offset-4 hover:text-primary-700;
	}

	/* AI badges */
	.ai-badges {
		@apply mt-5 flex flex-wrap gap-2;
	}

	.ai-badge {
		@apply px-4 py-2 text-sm font-medium rounded-full;
		background: #ffffff;
		border: 2px solid #d1d5db;
		color: #1e293b;
	}
</style>

<script>
	document.addEventListener('DOMContentLoaded', () => {
		const tabs = document.querySelectorAll('.framework-tab')
		const stepsTimeline = document.querySelector('.steps-timeline')
		const installCommand = document.querySelector('[data-install-command]')
		const portUrl = document.querySelector('[data-port-url]')
		const step1Title = stepsTimeline?.querySelector('[data-step1-title]')
		const step1Description = stepsTimeline?.querySelector('[data-step1-description]')
		const step2Title = stepsTimeline?.querySelector('[data-step2-title]')
		const step2Description = stepsTimeline?.querySelector('[data-step2-description]')
		const step3Title = stepsTimeline?.querySelector('[data-step3-title]')
		const step3Description = stepsTimeline?.querySelector('[data-step3-description]')
		const pluginDirectoryLink = document.querySelector('[data-plugin-directory-link]')

		// Framework tab switching
		tabs.forEach((tab) => {
			tab.addEventListener('click', () => {
				tabs.forEach((t) => t.classList.remove('active'))
				tab.classList.add('active')

				const command = tab.getAttribute('data-command')
				if (installCommand && command) {
					installCommand.textContent = command
				}

				const url = tab.getAttribute('data-url')
				if (portUrl && url) {
					portUrl.textContent = url
				}


				const updates = [
					{ element: step1Title, text: tab.getAttribute('data-step1-title') },
					{ element: step1Description, text: tab.getAttribute('data-step1-description') },
					{ element: step2Title, text: tab.getAttribute('data-step2-title') },
					{ element: step2Description, text: tab.getAttribute('data-step2-description') },
					{ element: step3Title, text: tab.getAttribute('data-step3-title') },
					{ element: step3Description, text: tab.getAttribute('data-step3-description') }
				]

				updates.forEach(({ element, text }) => {
					if (element && text) {
						element.textContent = text
					}
				})

				if (pluginDirectoryLink) {
					const showPluginLink = tab.getAttribute('data-show-plugin-link') === 'true'
					pluginDirectoryLink.toggleAttribute('hidden', !showPluginLink)
				}
			})
		})

		// Copy to clipboard (handles all copy buttons)
		document.querySelectorAll('.copy-button').forEach((btn) => {
			btn.addEventListener('click', async () => {
				const code = btn.closest('.terminal-body')?.querySelector('code')?.textContent
				if (code) {
					try {
						await navigator.clipboard.writeText(code)
						const originalHTML = btn.innerHTML
					btn.innerHTML = `
						<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2" aria-hidden="true">
							<polyline points="20 6 9 17 4 12"></polyline>
						</svg>
					`
						setTimeout(() => {
							btn.innerHTML = originalHTML
						}, 2000)
					} catch (err) {
						console.error('Failed to copy:', err)
					}
				}
			})
		})
	})
</script>
