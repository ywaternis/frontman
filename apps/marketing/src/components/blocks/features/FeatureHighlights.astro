---
// Feature Highlights Section
// ------------
// Description: Feature highlight rows with text on left and image/video on right, plus a compact features grid

// Components
// - Layout
import Row from '../../ui/Row.astro'
import Col from '../../ui/Col.astro'
// - Image
import { Image } from 'astro:assets'

type FeatureHighlight = {
	title: string
	description: string
	imageAlt: string
	image?: any
	videoSrc?: string
	svgSrc?: string
}

type CompactFeature = {
	icon: string
	title: string
	description: string
	color: string // tailwind gradient color
}

const featureHighlights: FeatureHighlight[] = [
	{
		title: 'Click any element. Tell it what you want.',
		description: 'Select a component directly in your browser — a button, a card, an entire section. Describe the change in plain English. No file hunting, no line numbers, no IDE.<br/><br/><span class="pro-tip">Pro tip: use the up and down arrows to move between components and divs</span>',
		imageAlt: 'Select elements feature demo',
		videoSrc: '/select-element.mp4'
	},
	{
		title: 'Watch your code change in real time.',
		description: 'No more alt-tabbing between editor and browser. Frontman updates your code as you describe changes — and you see the results live, instantly. When you\'re happy, commit and push to Git without ever leaving your browser.',
		imageAlt: 'Real-time changes feature demo',
		videoSrc: '/code-change.mp4'
	}
]

const compactFeatures: CompactFeature[] = [
	{
		icon: '🔍',
		title: 'Live DOM & component tree',
		description: 'Inspects the real DOM, CSS styles, and component boundaries — the full runtime context that file-level agents miss.',
		color: '#3b82f6'
	},
	{
		icon: '📱',
		title: 'Responsive testing',
		description: 'Switch between device presets — iPhone, iPad, desktop — and see how your changes look at every breakpoint.',
		color: '#a855f7'
	},
	{
		icon: '📋',
		title: 'Dev server logs & errors',
		description: 'Reads build output, console warnings, and stack traces. Spots compilation errors and fixes them automatically.',
		color: '#f59e0b'
	},
	{
		icon: '🔑',
		title: 'Bring your own key',
		description: 'Open-source core with BYOK model support. Use your API key from Anthropic, OpenAI, or OpenRouter for local development.',
		color: '#10b981'
	},
	{
		icon: '📐',
		title: 'Project rules, loaded automatically',
		description: 'Reads agents.md, claude.md, or custom rule files at session start. Your conventions baked into every prompt.',
		color: '#f43f5e'
	},
	{
		icon: '⚡',
		title: 'Multi-framework support',
		description: 'Works with Next.js, Astro, and Vite out of the box. React, Vue, Svelte — your framework, your rules.',
		color: '#eab308'
	}
]
---

{
	featureHighlights.map((feature, index) => (
		<section
			id={`feature-highlight-${index}`}
			class={`feature-section ${index % 2 === 0 ? 'bg-neutral-950' : 'bg-neutral-900'}`}
		>
			<div class="container">
				<Row classes="gap-8">
					<!-- Left side: Text content -->
					<Col spanMobile="12" span="5" classes={index === 1 ? 'lg:order-2' : ''}>
						<div class="feature-content">
							<h2 class="feature-title">{feature.title}</h2>
							<p class="feature-description" set:html={feature.description} />
						</div>
					</Col>

					<!-- Right side: Image/Video placeholder -->
					<Col spanMobile="12" span="7" classes={`flex items-center ${index === 1 ? 'lg:order-1' : ''}`}>
					<div class="media-placeholder" role="img" aria-label={feature.imageAlt}>
				{feature.videoSrc ? (
					<video
						loop
						muted
						playsinline
						width={620}
						height={431}
						class="media-image lazy-video"
						aria-label={feature.imageAlt}
						preload="none"
						data-src={feature.videoSrc}
					>
						<track kind="captions" src={index === 0 ? '/captions/select-element.vtt' : '/captions/code-change.vtt'} srclang="en" label="English" default />
					</video>
						) : feature.svgSrc ? (
					<img
							src={feature.svgSrc}
							alt={feature.imageAlt}
							width={620}
							class="media-image"
							loading="lazy"
						/>
						) : feature.image ? (
					<Image
							src={feature.image}
							alt={feature.imageAlt}
							width={620}
							format="webp"
							class="media-image"
							loading="lazy"
						/>
						) : (
							<div class="placeholder-content">
								{/* Image or video will go here */}
							</div>
						)}
						</div>
					</Col>
				</Row>
			</div>
		</section>
	))
}

<!-- Compact features grid -->
<section class="compact-features-section">
	<div class="section-glow"></div>
	<div class="container">
		<div class="compact-header">
			<h2 class="compact-title">And that's just the beginning.</h2>
			<p class="compact-subtitle">Everything you need to build faster, smarter, and with more confidence.</p>
		</div>
		<div class="feature-list">
			{compactFeatures.map((feature, i) => (
				<div class="feature-row">
					<div class="feature-number" style={`--accent: ${feature.color}`}>
						<span class="number-text">{String(i + 1).padStart(2, '0')}</span>
					</div>
					<div class="feature-body">
						<div class="feature-icon-title">
							<span class="fl-icon">{feature.icon}</span>
							<h3 class="fl-title">{feature.title}</h3>
						</div>
						<p class="fl-description">{feature.description}</p>
					</div>
				</div>
			))}
		</div>
	</div>
</section>

<script>
	if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
	const observer = new IntersectionObserver(
		(entries) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					const video = entry.target as HTMLVideoElement
					const src = video.dataset.src
					if (src) {
						const source = document.createElement('source')
						source.src = src
						source.type = 'video/mp4'
						video.appendChild(source)
						video.load()
						video.play().catch((err) => console.warn('Video autoplay blocked:', err))
						delete video.dataset.src
					}
					observer.unobserve(video)
				}
			})
		},
		{ rootMargin: '200px' }
	)

	document.querySelectorAll<HTMLVideoElement>('.lazy-video').forEach((video) => {
		observer.observe(video)
	})
	}
</script>

<style>
	@reference "../../../styles/global.css";
	.feature-section {
		@apply relative overflow-hidden pt-20 pb-12 lg:pt-32 lg:pb-16;
	}

	.container {
		@apply relative mx-auto px-6 max-w-7xl;
	}

	/* Content Side */
	.feature-content {
		@apply flex flex-col justify-center h-full pt-8 pb-0 lg:py-0;
		max-width: 540px;
	}

	.feature-title {
		@apply font-headings text-3xl lg:text-4xl font-bold text-white mb-5 relative;
		z-index: 100;
		line-height: 1.3;
	}

	.feature-description {
		@apply text-base lg:text-lg text-neutral-300 relative;
		z-index: 100;
		line-height: 1.7;
	}

	.feature-description :global(.pro-tip) {
		@apply text-sm text-neutral-400 italic;
		display: block;
		margin-top: 0.5rem;
	}

	/* Media Side */
	.media-placeholder {
		@apply bg-neutral-800 rounded-lg relative overflow-hidden w-full;
		z-index: 10;
		max-width: 620px;
	}

	.media-image {
		@apply w-full h-full object-cover;
	}

	.placeholder-content {
		@apply w-full h-full flex items-center justify-center;
	}

	/* Compact features section */
	.compact-features-section {
		@apply relative overflow-hidden py-24 lg:py-32;
		background: linear-gradient(180deg, #0a0a0a 0%, #111827 50%, #0a0a0a 100%);
	}

	.section-glow {
		@apply absolute inset-0 pointer-events-none;
		background:
			radial-gradient(ellipse 60% 40% at 20% 50%, rgba(59, 130, 246, 0.06) 0%, transparent 70%),
			radial-gradient(ellipse 50% 50% at 80% 30%, rgba(168, 85, 247, 0.05) 0%, transparent 70%);
	}

	.compact-header {
		@apply text-center mb-16 lg:mb-20 relative;
	}

	.compact-title {
		@apply font-headings text-4xl lg:text-6xl font-bold text-white mb-5;
		line-height: 1.1;
		letter-spacing: -0.02em;
	}

	.compact-subtitle {
		@apply text-lg lg:text-xl text-neutral-400 mx-auto;
		max-width: 480px;
		line-height: 1.5;
	}

	/* Feature list */
	.feature-list {
		@apply relative max-w-4xl mx-auto;
	}

	.feature-row {
		@apply relative flex gap-6 lg:gap-10 py-8 lg:py-10;
		border-bottom: 1px solid rgba(255, 255, 255, 0.06);
		transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.feature-row:first-child {
		border-top: 1px solid rgba(255, 255, 255, 0.06);
	}

	.feature-row:hover {
		padding-left: 8px;
	}

	.feature-row:hover .number-text {
		opacity: 1;
		transform: scale(1.1);
	}

	.feature-row:hover .fl-title {
		color: var(--accent);
	}

	.feature-number {
		@apply flex-shrink-0 flex items-start pt-1;
		width: 56px;
	}

	.number-text {
		@apply font-headings font-bold;
		font-size: 2rem;
		line-height: 1;
		color: var(--accent);
		opacity: 0.5;
		transition: all 0.4s ease;
	}

	.feature-body {
		@apply flex-1 min-w-0;
	}

	.feature-icon-title {
		@apply flex items-center gap-3 mb-2;
	}

	.fl-icon {
		@apply text-xl flex-shrink-0;
	}

	.fl-title {
		@apply font-headings text-xl lg:text-2xl font-semibold text-white;
		transition: color 0.4s ease;
	}

	.fl-description {
		@apply text-base text-neutral-400 leading-relaxed;
		max-width: 560px;
	}

	/* Responsive adjustments */
	@media (max-width: 1024px) {
		.feature-content {
			max-width: 100%;
		}

		.feature-title {
			@apply text-2xl lg:text-3xl mb-4;
		}

		.feature-description {
			@apply text-base;
		}

		.media-placeholder {
			max-width: 480px;
		}
	}

	@media (max-width: 640px) {
		.feature-section {
			padding-top: 2rem;
			padding-bottom: 2rem;
		}

		.feature-title {
			@apply text-xl mb-3;
		}

		.media-placeholder {
			max-width: 100%;
		}

		.compact-features-section {
			padding-top: 2.5rem;
			padding-bottom: 2.5rem;
		}

		.compact-header {
			margin-bottom: 2rem;
		}

		.compact-title {
			@apply text-3xl;
		}

		.feature-row:hover {
			padding-left: 0;
		}

		.feature-number {
			width: 40px;
		}

		.number-text {
			font-size: 1.5rem;
		}
	}
</style>
