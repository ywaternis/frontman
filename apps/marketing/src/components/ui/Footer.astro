---
// Footer
// ------------
// Description: the website footer is the section of content
// Reference: https://wind-ui.com/components/footers/

// Components
// - UI
import { Icon } from 'astro-icon/components'
import { Image } from 'astro:assets'
import logoSvg from '../../assets/logo.svg'

// Data
import { socialLinks } from '../../config/socialLinks'
import { footerNavigationData } from '../../config/footerNavigation'

const { footerAbout, footerColumns, subFooter } = footerNavigationData
---

<footer class="footer" role="contentinfo">
	<div class="footer__container">
		<!-- Top row: brand + nav columns -->
		<div class="footer__top">
			<a class="footer__brand" href="/">
				<Image src={logoSvg} alt={footerAbout.logo.alt} width={24} height={24} loading="lazy" />
				{footerAbout.logo.text}
			</a>

			<div class="footer__nav-columns">
				{
					footerColumns.map((column) => (
						<nav aria-label={`${column.category} links`} class="footer__nav-col">
							<h3>{column.category}</h3>
							<ul>
								{column.subCategories.map((subCategory) => (
									<li>
										<a
											href={subCategory.subCategoryLink}
											{...(subCategory.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
										>
											{subCategory.subCategory}
										</a>
									</li>
								))}
							</ul>
						</nav>
					))
				}
			</div>
		</div>

		<!-- Bottom row: copyright + legal + social -->
		<div class="footer__bottom">
			<div class="footer__bottom-left">
				<span>{subFooter.copywriteText}</span>
				{subFooter.links.length > 0 && (
					<nav aria-label="Legal links" class="footer__legal">
						{subFooter.links.map((link) => (
							<a href={link.href}>{link.label}</a>
						))}
					</nav>
				)}
			</div>
			<nav aria-label="Social media links">
				<ul>
					{
						socialLinks.map((social) => (
							<li>
								<a href={social.link} aria-label={`Frontman on ${social.name}`} rel="noopener noreferrer" target="_blank">
									<Icon name={social.icon} aria-hidden="true" />
								</a>
							</li>
						))
					}
				</ul>
			</nav>
		</div>
	</div>
</footer>

<style>
	@reference "../../styles/global.css";
	.footer {
		@apply border-t border-neutral-200 bg-neutral-50 text-sm text-neutral-500
			dark:border-neutral-800 dark:bg-neutral-950 dark:text-neutral-400;
	}
	.footer a {
		@apply transition-colors duration-200 hover:text-primary-500 focus:text-primary-600;
	}
	.footer__container {
		@apply mx-auto px-6 py-10;
		max-width: 1100px;
	}

	/* Top row */
	.footer__top {
		@apply flex flex-col gap-8;
	}
	.footer__brand {
		@apply flex items-center gap-2 whitespace-nowrap font-headings text-base font-semibold text-neutral-700 dark:text-neutral-100;
	}
	.footer__nav-columns {
		@apply grid grid-cols-2 gap-x-8 gap-y-8
			sm:grid-cols-3
			lg:grid-cols-6;
	}
	.footer__nav-col h3 {
		@apply mb-3 text-xs font-semibold uppercase tracking-wider text-neutral-700 dark:text-neutral-200;
	}
	.footer__nav-col ul {
		@apply space-y-2;
	}

	/* Bottom row */
	.footer__bottom {
		@apply mt-8 flex flex-col items-center justify-between gap-4 border-t border-neutral-200 pt-6 text-xs text-neutral-600
			dark:border-neutral-800 dark:text-neutral-400
			sm:flex-row;
	}
	.footer__bottom-left {
		@apply flex flex-col items-center gap-2 sm:flex-row sm:gap-4;
	}
	.footer__legal {
		@apply flex items-center gap-3;
	}
	.footer__legal a {
		@apply text-neutral-400 transition-colors duration-200 hover:text-primary-500 dark:text-neutral-400 dark:hover:text-primary-400;
	}
	.footer__bottom ul {
		@apply flex items-center gap-4;
	}
	.footer__bottom a {
		@apply [&_svg]:h-4 [&_svg]:w-4 [&_svg]:shrink-0;
	}
	.footer__bottom nav[aria-label="Social media links"] a {
		@apply flex items-center justify-center rounded-lg;
		min-height: 44px;
		min-width: 44px;
	}
</style>
