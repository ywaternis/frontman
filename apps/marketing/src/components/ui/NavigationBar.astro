---
// Header - Floating pill-style navigation bar
// ------------
// Description: Floating pill-style navigation bar inspired by creem.io.
// Structure:
// - Logo: the logo of the website
// - Menu toggle: the mobile menu toggle of the navigation bar
// - Navigation Links: the navigation links of the menu
// - Actions: action buttons for the navigation bar

// Components
// - UI
import { Icon } from 'astro-icon/components'

// Data
import { navigationBarData } from '../../config/navigationBar'
const { logo, navItems } = navigationBarData
const filteredNavItems = navItems.filter((item) => item.name !== 'Changelog' && item.name !== 'FAQ')

// Determine current path
const path = new URL(Astro.request.url).pathname
function isActivePath(currentPath: string): boolean {
	return path === currentPath || path === `${currentPath}/`
}
---

<header class="header">
	<div class="header__container">
		<nav aria-label="Main navigation" class="header__nav">
			<!-- Logo -->
			<a href="/" class="header__logo">
				<img src={logo.src} alt={logo.alt} width="32" height="32" />
				<span>{logo.text}</span>
			</a>

			<!-- Menu toggle -->
			<button
				id="header-toggle"
				class="header__toggle"
				aria-expanded="false"
				aria-label="Toggle navigation"
			>
				<div class="header__toggle-inner">
					<span aria-hidden="true"></span>
					<span aria-hidden="true"></span>
					<span aria-hidden="true"></span>
				</div>
			</button>

			<!-- Navigation action buttons -->
			<!-- Navigation links -->
			<ul class="header__menu">
				{
					filteredNavItems.map((item) => (
						<li class="header__menu-item">
							{!item.submenu ? (
								<a
									href={item.link}
									class={`header__menu-link ${isActivePath(item.link) ? 'active' : ''}`}
								>
									{item.name}
								</a>
							) : (
								<a
									href={item.link}
									aria-haspopup="true"
									aria-expanded="false"
									class={`header__menu-link ${isActivePath(item.link) ? 'active' : ''}`}
								>
									{item.name}
									<Icon name="chevron-down" class="header__menu-chevron" aria-hidden="true" />
								</a>
							)}
							{item.submenu && (
								<ul class="header__submenu">
									{item.submenu.map((subItem) => (
										<li class="header__submenu-item">
											<a
												href={subItem.link}
												class={`header__submenu-link ${isActivePath(subItem.link) ? 'active' : ''}`}
											>
												{subItem.name}
											</a>
										</li>
									))}
								</ul>
							)}
						</li>
					))
				}
			</ul>

			<!-- Navigation action buttons -->
			<div class="header__actions">
				<a href="https://github.com/frontman-ai/frontman" target="_blank" rel="noopener noreferrer" class="header__github-link" data-ga-event="click_star_github" data-ga-category="conversion" data-ga-label="nav">
					<Icon name="github-icon" class="header__github-icon" aria-hidden="true" />
					<span>Star on GitHub</span>
				</a>
				<a href="/#install" class="header__cta">Try it now</a>
			</div>
		</nav>
	</div>
</header>

<style>
	@reference "../../styles/global.css";

	/* -- Floating pill header -- */
	.header {
		@apply fixed top-0 left-0 right-0 z-[999] w-full;
		padding: 12px 16px 0;
	}
	@media (min-width: 1024px) {
		.header {
			padding: 14px 24px 0;
		}
	}
	.header__container {
		max-width: 1100px;
		margin: 0 auto;
	}
	.header__nav {
		@apply flex items-center;
		font-family: "SF Pro Display", system-ui, helvetica, sans-serif;
		height: 56px;
		padding: 0 8px 0 16px;
		border-radius: 16px;
		position: relative;
	}
	/* Use ::before for visual styling so backdrop-filter doesn't create a containing block for fixed children */
	.header__nav::before {
		content: '';
		position: absolute;
		inset: 0;
		border-radius: inherit;
		background: rgba(10, 10, 10, 0.75);
		backdrop-filter: blur(20px) saturate(1.4);
		-webkit-backdrop-filter: blur(20px) saturate(1.4);
		border: 1px solid rgba(255, 255, 255, 0.1);
		box-shadow: 0 4px 24px rgba(0, 0, 0, 0.25), 0 0 0 1px rgba(255, 255, 255, 0.05) inset;
		z-index: -1;
	}

	/* -- Logo -- */
	.header__logo {
		@apply flex flex-none items-center gap-2 whitespace-nowrap text-white;
		font-size: 16px;
		font-weight: 500;
		letter-spacing: -0.01em;
		text-decoration: none;
		z-index: 1000;
	}
	.header__logo img {
		width: 28px;
		height: 28px;
	}

	/* -- Nav links (centered) -- */
	.header__menu {
		@apply invisible fixed left-0 top-0 h-dvh w-full justify-center overflow-hidden overflow-y-auto overscroll-contain opacity-0 transition-[opacity,visibility] duration-300;
		z-index: 998;
		background: rgba(10, 10, 10, 0.97);
		list-style: none;
		margin: 12px 16px 0;
		padding: 5rem 2rem 2rem;
		width: calc(100% - 32px);
		height: calc(100dvh - 12px);
		border-radius: 16px;
	}
	@media (min-width: 1024px) {
		.header__menu {
			@apply visible relative top-0 z-0 flex h-auto w-auto items-center overflow-visible bg-transparent opacity-100;
			margin: 0 auto;
			padding: 0;
			gap: 2px;
		}
	}
	.header__menu--open {
		@apply visible opacity-100;
	}
	.header__menu-item {
		@apply relative flex cursor-pointer flex-col items-stretch lg:flex-row;
		list-style: none;
	}
	.header__menu-link {
		@apply relative flex items-center gap-1 text-white/70 transition-colors duration-200;
		font-size: 14px;
		line-height: 20px;
		font-weight: 400;
		padding: 8px 12px;
		border-radius: 8px;
		text-decoration: none;
		white-space: nowrap;
	}
	.header__menu-link:hover {
		color: white;
		background: rgba(255, 255, 255, 0.08);
	}
	.header__menu-link.active {
		color: white;
	}
	button.header__menu-link {
		@apply cursor-pointer border-none bg-transparent;
	}
	.header__menu-chevron {
		@apply h-3.5 w-3.5 transition-transform;
		opacity: 0.5;
	}
	@media (min-width: 1024px) {
		.header__menu-item:hover > .header__menu-link .header__menu-chevron,
		.header__menu-item:focus-within > .header__menu-link .header__menu-chevron {
			transform: rotate(180deg);
		}
	}

	/* -- Submenu dropdown -- */
	.header__submenu {
		@apply left-0 top-full hidden px-4 lg:absolute lg:min-w-[180px] lg:p-1.5;
		background: rgba(20, 20, 20, 0.95);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 12px;
		box-shadow: 0 12px 32px -4px rgba(0, 0, 0, 0.5);
		list-style: none;
	}
	/* Add invisible bridge to prevent hover gap issues */
	@media (min-width: 1024px) {
		.header__submenu::before {
			content: '';
			position: absolute;
			top: -4px;
			left: 0;
			right: 0;
			height: 4px;
		}
	}
	@media (max-width: 1023px) {
		.header__menu-item:hover > .header__submenu {
			display: none;
		}
		.header__menu-item.open > .header__submenu {
			display: block;
		}
		.header__menu-item.open > .header__menu-link .header__menu-chevron {
			transform: rotate(180deg);
		}
	}
	@media (min-width: 1024px) {
		.header__menu-item:hover > .header__submenu,
		.header__menu-item:focus-within > .header__submenu {
			display: block;
		}
		/* Add 4px vertical offset to maintain spacing */
		.header__submenu {
			transform: translateY(4px);
		}
	}

	.header__submenu-item {
		list-style: none;
	}
	.header__submenu-link {
		@apply flex items-center rounded-lg px-3 py-2 text-white/60 transition-all duration-200;
		font-size: 13px;
		line-height: 18px;
		font-weight: 400;
		text-decoration: none;
	}
	.header__submenu-link:hover {
		color: white;
		background: rgba(255, 255, 255, 0.08);
	}
	.header__submenu-link.active {
		color: white;
		background: rgba(255, 255, 255, 0.06);
	}

	/* -- Mobile toggle -- */
	.header__toggle {
		@apply relative order-10 block h-10 w-10 cursor-pointer self-center lg:hidden [&--open]:visible [&--open]:opacity-100;
		margin-left: auto;
		z-index: 1000;
	}
	.header__toggle-inner {
		@apply absolute left-1/2 top-1/2 w-6 -translate-x-1/2 -translate-y-1/2 transform;
	}
	.header__toggle-inner span {
		@apply absolute block h-0.5 transform rounded-full bg-white transition-all duration-300;
	}
	.header__toggle-inner span:nth-child(1) {
		@apply w-9/12 -translate-y-2 [.header\_\_toggle--open_&]:w-6 [.header\_\_toggle--open_&]:translate-y-0 [.header\_\_toggle--open_&]:rotate-45;
	}
	.header__toggle-inner span:nth-child(2) {
		@apply w-6 [.header\_\_toggle--open_&]:-rotate-45;
	}
	.header__toggle-inner span:nth-child(3) {
		@apply w-1/2 origin-top-left translate-y-2 [.header\_\_toggle--open_&]:w-0;
	}

	/* -- Right actions -- */
	.header__actions {
		@apply fixed bottom-0 left-0 hidden w-full items-center justify-between gap-2 px-6 py-4 lg:relative lg:ml-auto lg:flex lg:w-auto lg:px-0 lg:py-0 lg:gap-3 [.header\_\_menu--open~&]:flex;
		background: rgba(10, 10, 10, 0.97);
		border-top: 1px solid rgba(255, 255, 255, 0.1);
	}
	@media (min-width: 1024px) {
		.header__actions {
			background: transparent;
			border-top: none;
		}
	}
	.header__github-link {
		@apply hidden items-center gap-1.5 whitespace-nowrap text-white/60 transition-colors duration-200 hover:text-white lg:flex;
		font-size: 13px;
		font-weight: 450;
		text-decoration: none;
		padding: 6px 10px;
		border-radius: 8px;
	}
	.header__github-link:hover {
		background: rgba(255, 255, 255, 0.06);
	}
	.header__github-icon {
		@apply h-4 w-4;
	}
	.header__cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		font-family: "SF Pro Display", system-ui, helvetica, sans-serif;
		font-size: 13px;
		font-weight: 550;
		line-height: 1;
		color: black;
		background: white;
		padding: 8px 18px;
		border-radius: 10px;
		text-decoration: none;
		white-space: nowrap;
		transition: opacity 0.15s;
		flex: 1 1 auto;
	}
	@media (min-width: 1024px) {
		.header__cta {
			flex: none;
		}
	}
	.header__cta:hover {
		opacity: 0.88;
	}
</style>
