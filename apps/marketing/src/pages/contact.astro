---
import Layout from '../layouts/Layout.astro'
import { legalInfo } from '../data/legalInfo'

const SEO = {
	title: 'Contact Frontman',
	description:
		'Contact the Frontman team for setup help, bug reports, product questions, and early access feedback. Use support email, GitHub, Discord, or the docs.'
}

const contactOptions = [
	{
		title: 'Email support',
		description:
			'Best for installation help, account questions, self-hosting questions, and anything you want to send privately.',
		href: '#email-support',
		label: legalInfo.supportEmailDisplay
	},
	{
		title: 'Read the docs',
		description:
			'Start here for installation, API keys, framework integrations, troubleshooting, and self-hosting guidance.',
		href: '/docs/',
		label: 'Open documentation'
	},
	{
		title: 'GitHub repository',
		description:
			'Use GitHub for reproducible bug reports, feature requests, code contributions, and implementation discussion.',
		href: 'https://github.com/frontman-ai/frontman',
		label: 'View GitHub'
	},
	{
		title: 'Discord community',
		description:
			'Good for quick setup questions, workflow discussion, and feedback while you are actively trying the product.',
		href: 'https://discord.gg/xk8uXJSvhC',
		label: 'Join Discord'
	}
]

const faqs = [
	{
		question: 'Where should I report a bug?',
		answer: `If you can share reproduction steps publicly, GitHub is the best place. If the issue includes private project details, email ${legalInfo.supportEmailDisplay} instead.`
	},
	{
		question: 'What should I include when asking for help?',
		answer:
			'Include your framework, package versions, the exact command you ran, the error message, and a screenshot or console output if possible. That usually shortens the back-and-forth dramatically.'
	},
	{
		question: 'Can I ask about self-hosting or team rollout?',
		answer: `Yes. Email ${legalInfo.supportEmailDisplay} with your environment details and goals, and include links to any docs pages you already checked so the conversation starts with context.`
	}
]

const jsonLd = {
	'@context': 'https://schema.org',
	'@graph': [
		{
			'@type': 'ContactPage',
			name: 'Contact Frontman',
			url: 'https://frontman.sh/contact/'
		},
		{
			'@type': 'Organization',
			name: legalInfo.brandName,
			url: 'https://frontman.sh/',
			contactPoint: [
				{
					'@type': 'ContactPoint',
					contactType: 'customer support',
					email: legalInfo.supportEmail
				}
			],
			sameAs: ['https://github.com/frontman-ai/frontman', 'https://discord.gg/xk8uXJSvhC']
		}
	]
}
---

<Layout title={SEO.title} description={SEO.description}>
	<script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

	<section class="border-b border-neutral-200 bg-neutral-50 py-20 dark:border-neutral-800 dark:bg-neutral-950">
		<div class="mx-auto max-w-3xl px-6 text-center">
			<p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary-500">Contact</p>
			<h1 class="mt-4 text-4xl font-bold tracking-tight text-neutral-950 dark:text-white sm:text-5xl">
				Talk to the Frontman team.
			</h1>
			<p class="mt-6 text-lg leading-8 text-neutral-600 dark:text-neutral-300">
				Use support email, the docs, GitHub, or Discord depending on what you need. The fastest
				path usually depends on whether your question is private, reproducible, or just easier to
				work through in public.
			</p>
		</div>
	</section>

	<section class="py-16 sm:py-20">
		<div class="mx-auto max-w-6xl px-6">
			<div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
				{contactOptions.map((option) => (
					<a
						id={option.href === '#email-support' ? 'email-support' : undefined}
						href={option.href}
						class="rounded-3xl border border-neutral-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:border-primary-300 hover:shadow-md dark:border-neutral-800 dark:bg-neutral-900 dark:hover:border-primary-600"
					>
						<h2 class="text-xl font-semibold text-neutral-950 dark:text-white">{option.title}</h2>
						<p class="mt-3 text-sm leading-6 text-neutral-600 dark:text-neutral-300">{option.description}</p>
						<p class="mt-6 text-sm font-semibold text-primary-500">{option.label}</p>
					</a>
				))}
			</div>
		</div>
	</section>

	<section class="border-y border-neutral-200 bg-neutral-50 py-16 dark:border-neutral-800 dark:bg-neutral-950">
		<div class="mx-auto grid max-w-5xl gap-10 px-6 lg:grid-cols-[1.1fr_0.9fr]">
			<div>
				<h2 class="text-3xl font-bold tracking-tight text-neutral-950 dark:text-white">Before you reach out</h2>
				<p class="mt-4 text-base leading-7 text-neutral-600 dark:text-neutral-300">
					A little context makes support dramatically faster. When possible, include:
				</p>
				<ul class="mt-6 space-y-3 text-sm leading-6 text-neutral-700 dark:text-neutral-200">
					<li class="flex gap-3"><span class="mt-1 text-primary-500">•</span><span>Your framework and version (Next.js, Astro, or Vite)</span></li>
					<li class="flex gap-3"><span class="mt-1 text-primary-500">•</span><span>The exact install or runtime command you used</span></li>
					<li class="flex gap-3"><span class="mt-1 text-primary-500">•</span><span>The full error message, stack trace, or screenshot</span></li>
					<li class="flex gap-3"><span class="mt-1 text-primary-500">•</span><span>What you expected to happen instead</span></li>
				</ul>
			</div>

			<div class="rounded-3xl border border-neutral-200 bg-white p-8 shadow-sm dark:border-neutral-800 dark:bg-neutral-900">
				<h2 class="text-xl font-semibold text-neutral-950 dark:text-white">Useful starting points</h2>
				<ul class="mt-4 space-y-3 text-sm leading-6 text-neutral-600 dark:text-neutral-300">
					<li><a class="underline underline-offset-4" href="/docs/installation/">Installation guide</a></li>
					<li><a class="underline underline-offset-4" href="/docs/reference/troubleshooting/">Troubleshooting</a></li>
					<li><a class="underline underline-offset-4" href="/docs/reference/self-hosting/">Self-hosting docs</a></li>
					<li><a class="underline underline-offset-4" href="/how-it-works/">How Frontman works</a></li>
				</ul>
			</div>
		</div>
	</section>

	<section class="py-16 sm:py-20">
		<div class="mx-auto max-w-4xl px-6">
			<h2 class="text-3xl font-bold tracking-tight text-neutral-950 dark:text-white">Frequently asked questions</h2>
			<div class="mt-8 space-y-4">
				{faqs.map((faq) => (
					<details class="rounded-2xl border border-neutral-200 bg-white p-6 dark:border-neutral-800 dark:bg-neutral-900">
						<summary class="cursor-pointer list-none text-lg font-semibold text-neutral-950 dark:text-white">
							{faq.question}
						</summary>
						<p class="mt-4 text-base leading-7 text-neutral-600 dark:text-neutral-300">{faq.answer}</p>
					</details>
				))}
			</div>
		</div>
	</section>
</Layout>
