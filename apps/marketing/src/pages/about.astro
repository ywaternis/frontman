---
// About Page
// ------------
// Description: Meet the founders of Frontman.

// Components
import FounderCard from '../components/ui/cards/FounderCard.astro'
import Layout from '../layouts/Layout.astro'

// Content
const SEO = {
	title: 'About Frontman',
	description:
		'Frontman is built by Danni Friedland and Itay Adler — two co-founders who believe AI coding tools should see what developers see.'
}

const founders = [
	{
		firstName: 'Danni',
		lastName: 'Friedland',
		location: 'Berlin, Germany',
		bio: 'Co-founder of Frontman. Previously founded Walnut Inc, a category leader in sales tech. Focused on developer tools and the intersection of AI and frontend engineering.',
		github: 'https://github.com/BlueHotDog',
		linkedin: 'https://www.linkedin.com/in/dannifriedland/',
		twitter: 'https://twitter.com/dannifriedland',
	},
	{
		firstName: 'Itay',
		lastName: 'Adler',
		location: 'Israel',
		bio: 'Co-founder of Frontman. Background in full-stack engineering and product development. Focused on making AI tools that understand running applications, not just source files.',
		github: 'https://github.com/itayadler',
		linkedin: 'https://www.linkedin.com/in/itay-adler-93a4bb6/',
		twitter: 'https://twitter.com/itayad',
	},
]

// Person schema for each founder
const personSchemas = founders.map((founder) => ({
	'@context': 'https://schema.org',
	'@type': 'Person',
	name: `${founder.firstName} ${founder.lastName}`,
	jobTitle: 'Co-founder',
	worksFor: {
		'@type': 'Organization',
		name: 'Frontman',
		url: 'https://frontman.sh/',
	},
	sameAs: [founder.github, founder.linkedin, founder.twitter].filter(Boolean),
}))
---

<Layout title={SEO.title} description={SEO.description}>
	{personSchemas.map((schema) => (
		<script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
	))}

	<div class="flex min-h-screen justify-center bg-zinc-950 px-5 py-12 text-zinc-50 sm:px-6 sm:py-20 md:pb-30">
		<div class="w-full max-w-[720px]">
			<!-- Header -->
			<p class="mb-3 font-mono text-[13px] uppercase tracking-[0.12em] text-zinc-500">About</p>
			<h1 class="mb-3 text-[32px] leading-[1.1] font-bold tracking-[-0.02em] text-zinc-50 sm:text-[42px]">About Frontman</h1>
			<p class="mb-3 text-[22px] leading-[1.3] font-medium tracking-[-0.01em] text-zinc-400">Built by developers, for developers</p>
			<p class="mb-12 max-w-[580px] text-[17px] leading-[1.6] text-zinc-500 sm:mb-20">
				Frontman is an open-source AI coding agent that lives inside your browser. It sees your live DOM, understands your running application, and edits your actual source code. We built it because every other AI coding tool was blind to the UI.
			</p>

			<!-- Founders -->
			<div class="mb-20 grid grid-cols-1 gap-8 sm:grid-cols-2 sm:gap-10">
				{founders.map((founder) => (
					<FounderCard {...founder} />
				))}
			</div>

			<!-- Open Source callout -->
			<div class="border-t border-zinc-800 pt-12">
				<h2 class="mb-2 text-xl font-semibold tracking-[-0.01em] text-zinc-50">Open source from day one</h2>
				<p class="mb-4 max-w-[560px] text-[15px] leading-[1.7] text-zinc-400">
					Frontman is open source. Our client libraries are licensed under Apache 2.0, and the server is licensed under AGPL-3.0. You can read every line of code, every prompt we send to the LLM, and every edit we make to your files. Contributions are welcome.
				</p>
				<p class="mb-4 max-w-[560px] text-[15px] leading-[1.7] text-zinc-400">
					We also contribute a portion of revenue to carbon removal through <a href="https://climate.stripe.com/p0ClMe" target="_blank" rel="noopener noreferrer" class="text-zinc-50 underline decoration-zinc-600 underline-offset-[0.18em] transition-colors transition-[text-decoration-color] hover:text-zinc-300 hover:decoration-zinc-400">Stripe Climate</a> as part of our climate pledge.
				</p>
				<a href="https://github.com/frontman-ai/frontman" target="_blank" rel="noopener noreferrer" class="text-[15px] font-medium text-zinc-50 no-underline transition-colors hover:text-zinc-400">
					View on GitHub &rarr;
				</a>
			</div>
		</div>
	</div>
</Layout>
