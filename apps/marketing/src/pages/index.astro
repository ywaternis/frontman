---
import Layout from '../layouts/Layout.astro'
import Hero from '../components/blocks/hero/HomeCTA.astro'
import FullContextSection from '../components/blocks/context/FullContextSection.astro'
import FeatureHighlights from '../components/blocks/features/FeatureHighlights.astro'
import FrameworkSupport from '../components/blocks/frameworks/FrameworkSupport.astro'
import ComparisonTable from '../components/blocks/comparison/ComparisonTable.astro'

import InstallSteps from '../components/blocks/install/InstallSteps.astro'
import HomeFAQ from '../components/blocks/FAQ/HomeFAQ.astro'
import FinalCTA from '../components/blocks/CTA/FinalCTA.astro'

// Data
import faqData from '../data/json-files/faqData.json'

// Content
// - SEO
const SEO = {
	title: 'Frontman: Visual AI Frontend Editing',
	description:
		'Click any element, describe changes in plain English, get real code edits. Frontman sees your live DOM and running app. Open-source core with BYOK model support.'
}

// FAQPage JSON-LD
const faqJsonLd = {
	"@context": "https://schema.org",
	"@type": "FAQPage",
	"mainEntity": faqData.map((faq) => ({
		"@type": "Question",
		"name": faq.question,
		"acceptedAnswer": {
			"@type": "Answer",
			"text": faq.reply
		}
	}))
}

---

<Layout title={SEO.title} description={SEO.description}>
	<script is:inline type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
	<!-- Act 1: The Insight — hook them, then show why we're different -->
	<Hero />
	<FullContextSection />

	<!-- Act 2: The Product — show what it does, prove it fits -->
	<FeatureHighlights />
	<FrameworkSupport />

	<!-- Act 3: The Proof — rational validation -->
	<ComparisonTable />
	<section class="bg-neutral-950 px-6 py-10 text-center text-neutral-300">
		<p class="mx-auto max-w-3xl text-base leading-relaxed">
			Comparing AI tools for UI work? Read the <a href="/blog/best-frontend-coding-agent/" class="font-semibold text-primary-300 underline underline-offset-4 hover:text-primary-200">frontend coding agent</a> guide for Cursor, GitHub Copilot, Claude Code, v0, Bolt.new, Kombai, Stagewise, and Frontman.
		</p>
	</section>

	<!-- Act 4: The Close — make it easy, handle objections, seal the deal -->
	<InstallSteps />
	<HomeFAQ />
	<FinalCTA />
</Layout>
