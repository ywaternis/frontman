---
// Imports
// Components
import NavigationBar from '../components/ui/NavigationBar.astro'
import Main from '../components/ui/Main.astro'
import Footer from '../components/ui/Footer.astro'
// import Modal from '../components/blocks/modal/SignUp.astro'
import Header from '../components/blocks/head/Header.astro'
// Scripts
import Scriprs from '../components/scripts/LocalScripts.astro'
// Styles
import '../styles/global.css'
import '../cookiebanner/styles.css'
// Fonts
import '@fontsource-variable/inter'
import '@fontsource-variable/outfit'

// Props
type Props = {
	title?: string
	description?: string
	ogImage?: string
	ogImageWidth?: number
	ogImageHeight?: number
	ogImageAlt?: string
	noindex?: boolean
	classes?: string
	article?: {
		publishedTime?: string
		modifiedTime?: string
		tags?: string[]
	}
	breadcrumbs?: {
		name: string
		url: string
	}[]
}
// Page Metadata
const {
	title,
	description,
	ogImage,
	ogImageWidth,
	ogImageHeight,
	ogImageAlt,
	noindex,
	classes,
	article,
	breadcrumbs
} = Astro.props
---

<!doctype html>
<html lang="en" class="relative">
	<Header title={title} description={description} ogImage={ogImage} ogImageWidth={ogImageWidth} ogImageHeight={ogImageHeight} ogImageAlt={ogImageAlt} noindex={noindex} article={article} breadcrumbs={breadcrumbs} />
	<body class:list={[{ [`${classes}`]: classes }]}>
		<a href="#main-content" class="skip-link">Skip to main content</a>
		<NavigationBar />
		<Main>
			<slot />
		</Main>
		<Footer />
		<!-- <Modal /> -->
		<!-- <Toast /> -->
		<Scriprs />
	</body>
</html>
